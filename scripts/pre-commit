#!/bin/bash
# Git pre-commit hook for HotPlex
# Fast checks to ensure code health before commit

set -e

# ANSI color codes
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🔍 Running pre-commit checks...${NC}"

# 1. Format Check (go fmt)
echo "🔹 Checking code formatting (go fmt)..."
DIFF=$(gofmt -d $(find . -name "*.go" -not -path "./vendor/*"))
if [ -n "$DIFF" ]; then
    echo -e "${YELLOW}⚠️  Code is not formatted correctly. Please run 'go fmt ./...'${NC}"
    echo "$DIFF"
    exit 1
fi

# 2. Dependency Check (go mod tidy)
echo "🔹 Verifying dependencies (go mod tidy)..."
go mod tidy
if ! git diff --exit-code go.mod go.sum > /dev/null; then
    echo -e "${YELLOW}⚠️  go.mod or go.sum are out of sync. Please run 'go mod tidy' and stage the changes.${NC}"
    exit 1
fi

# 3. Check for forbidden placeholders/debug code
echo "🔹 Scanning for 'TODO' or debug markers in staged files..."
# Just an example, can be customized
FORBIDDEN_PATTERNS=("fmt\.Printf" "panic(" "DEBUG_ONLY")
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep ".go$" || true)

if [ -n "$STAGED_FILES" ]; then
    for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
        if grep -n "$pattern" $STAGED_FILES; then
            echo -e "${YELLOW}⚠️  Found forbidden pattern '$pattern' in staged code. Please review.${NC}"
            # exit 1 # Uncomment to make it blocking
        fi
    done
fi

echo -e "${GREEN}✅ Pre-commit checks passed!${NC}"
exit 0

#!/bin/bash
# Git pre-push hook for HotPlex
# Final guard before code leaves the local machine

set -e

# ANSI color codes
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${YELLOW}🚀 Running final pre-push validation...${NC}"

# 1. Build validation (Ensures the main binary is at least buildable)
echo "� Verifying build (cmd/hotplexd)..."
if ! go build -o /dev/null ./cmd/hotplexd/main.go; then
    echo -e "${RED}❌ Build failed! Please fix compilation errors before pushing.${NC}"
    exit 1
fi

# 2. Run golangci-lint
if command -v golangci-lint &> /dev/null; then
    echo "🔹 Running linter (golangci-lint)..."
    golangci-lint run ./...
else
    echo -e "${YELLOW}⚠️  golangci-lint not found, skipping linting.${NC}"
fi

# 3. Run Go tests (with Race Detection)
echo "🔹 Running unit tests with race detection..."
if ! go test -v -race ./...; then
    echo -e "${RED}❌ Tests failed! Push aborted.${NC}"
    exit 1
fi

echo -e "${GREEN}✅ All quality gates passed! Push authorized.${NC}"
exit 0
